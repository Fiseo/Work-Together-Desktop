<UserControl x:Class="WorkTogether.WPF.AdminView.Form.ServiceCallTypeForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkTogether.WPF.AdminView.Form"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Grid.Column="1">

            <Border Background="#F9FAFB" Padding="15" CornerRadius="5" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TitleForm" Text="Créer un nouveau type d'intervention" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15"/>

                    <TextBlock Text="Libellé du type d'intervention :" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtNewLabel" Height="28" Padding="3" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                    <Frame x:Name="Btn" NavigationUIVisibility="Hidden"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
