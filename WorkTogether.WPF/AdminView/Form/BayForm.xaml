<UserControl x:Class="WorkTogether.WPF.AdminView.Form.BayForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkTogether.WPF.AdminView.Form"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel>

            <Border Background="#F9FAFB" Padding="15" CornerRadius="5" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TitleForm" Text="Créer une nouvelle baie" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15"/>

                    <TextBlock Text="Nom de la baie :" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtLabel" Height="28" Padding="3" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                    <Grid Margin="0,0,0,10" Cursor="Hand">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombre d'unité :" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtNbrUnit" Height="28" Padding="3" VerticalContentAlignment="Center" Text="42" IsReadOnly="False"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Nom des unités (sera suivi de son numéro) :" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtUnitLabel" Height="28" Padding="3" VerticalContentAlignment="Center" Text="U"/>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="Create" Content="Ajouter la baie" Height="35" Background="#10B981" Foreground="White" 
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Save_Click" Margin="0,10,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="Delete" Content="Supprimer la baie" Height="35" Background="Red" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Delete_Click" Visibility="Collapsed" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="Clear" Content="Désélectionner" Height="35" Background="Blue" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Clear_Click" Visibility="Collapsed" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
