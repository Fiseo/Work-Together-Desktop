<UserControl x:Class="WorkTogether.WPF.AdminView.List.Booking"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkTogether.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:BoolToStringConverter x:Key="BoolToStr"/>
    </UserControl.Resources> 
    <Grid>
        <DataGrid x:Name="DataGrid" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" 
  SelectionMode="Single"
  Background="White" BorderBrush="#E5E7EB" RowBackground="White" AlternatingRowBackground="#F9FAFB"
  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB" HeadersVisibility="Column" Margin="0,0,20,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="auto"/>
                <DataGridTextColumn Header="N° de commande" Binding="{Binding Label}" Width="auto" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Client" Binding="{Binding Client.Label}" Width="auto" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Offre" Binding="{Binding Offer.Label}" Width="auto" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Start, StringFormat={}{0:dd/MM/yyyy}}" Width="auto"/>
                <DataGridTextColumn Header="Technicien" Binding="{Binding End, StringFormat={}{0:dd/MM/yyyy}}" Width="auto"/>
                <DataGridTextColumn Header="Type de renouvellement" 
                            Binding="{Binding IsMonthly, Converter={StaticResource BoolToStr}, ConverterParameter='Mensuel|Annuel'}"
                            Width="auto"/>
                <DataGridTextColumn Header="Sera renouvelée" 
                            Binding="{Binding IsRenewable, Converter={StaticResource BoolToStr}, ConverterParameter='Oui|Non'}"
                            Width="auto"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="auto" FontWeight="SemiBold"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
