<UserControl x:Class="WorkTogether.WPF.AdminView.ReadPage.Bay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" 
             Background="White" av:DesignHeight="502.036" av:DesignWidth="827.069">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Liste des Baies" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,20"/>

        <DataGrid x:Name="DataGrid" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" 
          SelectionMode="Single"
          Background="White" BorderBrush="#E5E7EB" RowBackground="White" AlternatingRowBackground="#F9FAFB"
          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB" HeadersVisibility="Column" Margin="0,0,20,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="150" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Nombre d'unité" Binding="{Binding NumberUnit}" Width="150" FontWeight="SemiBold"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
